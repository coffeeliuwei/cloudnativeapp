<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="ExpressTrackMapper" >
    <resultMap id="BaseResultMap" type="com.coffee.yun.expresstrack.api.dto.ExpressTrackInfoResultDTO">
        <result column="order_id" property="order_id" jdbcType="VARCHAR"/>
        <result column="express_id" property="express_id" jdbcType="VARCHAR" />
        <result column="express_weight" property="express_weight" jdbcType="VARCHAR" />
        <result column="track_id" property="track_id" jdbcType="VARCHAR" />
        <result column="track_show" property="track_show" jdbcType="VARCHAR" />
    </resultMap>
    <!--
        创建快递单
        由 ExpresstrackInfoServiceImpl.createExpress() 调用，
        在 coffee-app 的 /createOrder 接口通过 Dubbo RPC 触发。
    -->
    <insert id="insertExpress" parameterType="map">
        INSERT INTO `express` (express_id, order_id, express_weight)
        VALUES (#{express_id}, #{order_id}, #{express_weight})
    </insert>

    <!--
        创建快递轨迹节点
        快递单创建后紧接着写入第一条轨迹（"商家已揽件"），
        在同一次 Dubbo RPC 调用中完成，与 insertExpress 顺序执行。
    -->
    <insert id="insertTrack" parameterType="map">
        INSERT INTO `track` (track_id, express_id, track_show)
        VALUES (#{track_id}, #{express_id}, #{track_show})
    </insert>

    <select id="selectByParam" resultMap="BaseResultMap" parameterType="com.coffee.yun.expresstrack.api.dto.ExpressTrackInfoParamDTO">
        SELECT express.express_id,
        order_id,
        express_weight,
        track_id,
        track_show
        FROM `express`
        LEFT JOIN `track` on `express`.`express_id`= `track`.`express_id`
        <where>
            <if test="order_id!=null and order_id!=''">
                order_id = #{order_id,jdbcType=VARCHAR}
            </if>
        </where>
    </select>
</mapper>